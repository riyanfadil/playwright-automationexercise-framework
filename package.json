  "devDependencies": {
    "@faker-js/faker": "^8.0.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "allure-commandline": "^2.27.0",
    "allure-playwright": "^2.15.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.0.0"
  }
}
